---

<footer class="border-t border-ash/10 mt-24">
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-12 md:py-16">
    <div
      class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8"
    >
      <!-- Left -->
      <div class="flex items-center gap-4">
        <img
          src="/logo.svg"
          alt=""
          class="h-6 w-auto opacity-40"
          aria-hidden="true"
        />
        <div>
          <p class="font-mono text-[10px] uppercase tracking-[3px] text-ash/50">
            Intermicronational Art Gallery 2026
          </p>
          <p class="font-mono text-[9px] text-ash/30 mt-1">
            "First Impression" — From a private thought to a public reality.
          </p>
        </div>
      </div>

      <!-- Right -->
      <div class="flex flex-col items-start md:items-end gap-2">
        <a
          href="https://discord.gg/FjNDTaxrz"
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-[9px] text-spark/60 hover:text-spark transition-colors uppercase tracking-wider"
        >
          Submit via Discord → #cultural-exhibition
        </a>
        <p class="font-mono text-[9px] text-ash/30">
          gallery.sakorn.com · MMXXVI
        </p>
      </div>
    </div>

    <!-- Red thread accent -->
    <div
      class="mt-8 h-px bg-linear-to-r from-transparent via-spark/30 to-transparent"
    >
    </div>

    <p
      class="text-center font-mono text-[8px] text-ash/20 uppercase tracking-[6px] mt-6"
    >
      All artworks remain property of their respective creators
    </p>
  </div>
</footer>
