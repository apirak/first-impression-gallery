---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import ArtworkCard from "../../components/ArtworkCard.astro";
import VibeFilter from "../../components/VibeFilter.astro";
import Footer from "../../components/Footer.astro";
import { artworks } from "../../data/artworks";
---

<BaseLayout
  title="The Diplomatic Archives — Intermicronational Art Gallery 2026"
>
  <Navigation />

  <main class="pt-28 md:pt-36 pb-12">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <!-- Section header -->
      <div class="mb-4">
        <p
          class="font-mono text-[9px] uppercase tracking-[4px] text-spark/60 mb-3"
        >
          Diplomatic Archives — Sector Index
        </p>
        <h1 class="font-serif font-light text-3xl md:text-5xl tracking-wide">
          The Gallery
        </h1>
        <div
          class="h-px bg-gradient-to-r from-spark/40 to-transparent mt-6 mb-2"
        >
        </div>
      </div>

      <!-- Vibe Filter -->
      <VibeFilter />

      <!-- Exhibit count -->
      <p
        id="exhibit-count"
        class="font-mono text-[9px] text-ash/30 uppercase tracking-wider mb-8"
      >
        {artworks.length} exhibit{artworks.length !== 1 ? "s" : ""} on record
      </p>

      <!-- Artwork Grid -->
      <div
        id="artwork-grid"
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 md:gap-4"
      >
        {
          artworks.map((artwork) => (
            <div data-vibes={JSON.stringify(artwork.vibe)}>
              <ArtworkCard artwork={artwork} />
            </div>
          ))
        }
      </div>

      <div id="no-results" class="text-center py-24 hidden">
        <p class="font-mono text-[11px] text-ash/40 uppercase tracking-[3px]">
          No exhibits found for this classification
        </p>
        <p class="font-mono text-[9px] text-ash/20 mt-2">
          Try selecting a different vibe filter
        </p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  function filterArtworks() {
    const params = new URLSearchParams(window.location.search);
    const vibe = params.get("vibe") || "all";
    const grid = document.getElementById("artwork-grid");
    const countEl = document.getElementById("exhibit-count");
    const noResults = document.getElementById("no-results");
    if (!grid) return;

    const cards = grid.querySelectorAll<HTMLElement>("[data-vibes]");
    let visible = 0;

    cards.forEach((card) => {
      const vibes: string[] = JSON.parse(card.dataset.vibes || "[]");
      const show = vibe === "all" || vibes.includes(vibe);
      card.style.display = show ? "" : "none";
      if (show) visible++;
    });

    if (countEl) {
      countEl.textContent = `${visible} exhibit${visible !== 1 ? "s" : ""} on record`;
    }
    if (noResults) {
      noResults.classList.toggle("hidden", visible > 0);
    }
  }

  filterArtworks();
</script>
