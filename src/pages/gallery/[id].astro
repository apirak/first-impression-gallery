---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import { artworks, vibeLabels, getArtworkById } from "../../data/artworks";

export function getStaticPaths() {
  return artworks.map((artwork) => ({
    params: { id: artwork.id },
  }));
}

const { id } = Astro.params;
const artwork = getArtworkById(id!);

if (!artwork) {
  return Astro.redirect("/gallery");
}

const vibeList = artwork.vibe.map((v) => vibeLabels[v] || v);
---

<BaseLayout title={`${artwork.title} — Intermicronational Art Gallery 2026`}>
  <Navigation />

  <main class="pt-28 md:pt-36 pb-12">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <!-- Back link -->
      <a
        href="/gallery"
        class="inline-flex items-center gap-2 font-mono text-[10px] uppercase tracking-[3px] text-ash/40 hover:text-spark transition-colors duration-300 mb-8"
      >
        <span class="text-spark">←</span> Return to Archives
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-16">
        <!-- Artwork Image -->
        <div class="lg:col-span-3">
          <div class="relative">
            <img
              src={artwork.image}
              alt={artwork.title}
              class="w-full h-auto object-contain bg-void"
              style={`view-transition-name: artwork-${artwork.id}`}
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
            />
            <!-- Fallback placeholder -->
            <div
              class="w-full aspect-[4/5] flex-col items-center justify-center bg-void border border-ash/10 hidden"
            >
              <div
                class="font-mono text-[11px] text-ash/30 uppercase tracking-[4px] mb-3"
              >
                {artwork.exhibitNumber}
              </div>
              <div class="font-serif text-2xl text-bone/15 italic">
                {artwork.title}
              </div>
              <div class="mt-6 w-16 h-px bg-spark/20"></div>
              <div class="font-mono text-[10px] text-ash/15 mt-3">
                {artwork.medium}
              </div>
              <div class="font-mono text-[9px] text-ash/10 mt-1">
                Image pending declassification
              </div>
            </div>
          </div>
        </div>

        <!-- Artwork Details (Declassified Document Style) -->
        <div class="lg:col-span-2">
          <!-- Classification header -->
          <div class="border border-ash/10 p-6 md:p-8 relative">
            <!-- Corner accents -->
            <div
              class="absolute top-0 left-0 w-3 h-3 border-t border-l border-spark/40"
            >
            </div>
            <div
              class="absolute top-0 right-0 w-3 h-3 border-t border-r border-spark/40"
            >
            </div>
            <div
              class="absolute bottom-0 left-0 w-3 h-3 border-b border-l border-spark/40"
            >
            </div>
            <div
              class="absolute bottom-0 right-0 w-3 h-3 border-b border-r border-spark/40"
            >
            </div>

            <!-- Exhibit number stamp -->
            <div class="flex items-center justify-between mb-6">
              <span
                class="font-mono text-[10px] text-spark uppercase tracking-[3px]"
              >
                {artwork.exhibitNumber}
              </span>
              <div class="flex flex-wrap gap-2">
                {
                  vibeList.map((label) => (
                    <div class="stamp animate">{label}</div>
                  ))
                }
              </div>
            </div>

            <div class="h-px bg-ash/10 mb-6"></div>

            <!-- Title -->
            <h1
              class="font-serif font-light text-2xl md:text-3xl tracking-wide mb-2"
            >
              {artwork.title}
            </h1>

            <p
              class="font-mono text-[11px] text-ash uppercase tracking-[2px] mb-6"
            >
              {artwork.artist}
            </p>

            <!-- Metadata grid -->
            <div class="space-y-4 mb-8">
              <div>
                <span
                  class="font-mono text-[9px] text-ash/40 uppercase tracking-wider block mb-1"
                >
                  Medium
                </span>
                <span class="font-sans text-sm text-bone/70">
                  {artwork.medium}
                </span>
              </div>
              <div>
                <span
                  class="font-mono text-[9px] text-ash/40 uppercase tracking-wider block mb-1"
                >
                  Coordinates
                </span>
                <span class="font-mono text-[11px] text-bone/50">
                  {artwork.coordinates}
                </span>
              </div>
            </div>

            <div class="h-px bg-ash/10 mb-6"></div>

            <!-- Description -->
            <p class="font-sans text-sm text-bone/60 leading-relaxed">
              {artwork.description}
            </p>
          </div>

          <!-- Discord Origin Stamp (Passport Style) -->
          <div class="mt-6 border border-ash/10 p-6 relative">
            <p
              class="font-mono text-[8px] uppercase tracking-[4px] text-ash/30 mb-4"
            >
              Origin Documentation
            </p>

            <!-- Passport stamp container -->
            <div
              class="relative border-2 border-dashed border-spark/20 p-4 rounded-sm"
            >
              <div class="absolute -top-2 left-4 bg-void px-2">
                <span
                  class="font-mono text-[8px] text-spark/40 uppercase tracking-wider"
                >
                  Discord Verified
                </span>
              </div>

              <div class="space-y-2">
                <div class="flex items-center gap-2">
                  <span class="font-mono text-[9px] text-ash/40"
                    >SUBMITTED BY</span
                  >
                  <span class="font-mono text-[11px] text-bone/70"
                    >{artwork.discord.user}</span
                  >
                </div>
                <div class="flex items-center gap-2">
                  <span class="font-mono text-[9px] text-ash/40">CHANNEL</span>
                  <span class="font-mono text-[11px] text-bone/70"
                    >{artwork.discord.channel}</span
                  >
                </div>
                <div class="flex items-center gap-2">
                  <span class="font-mono text-[9px] text-ash/40">DATE</span>
                  <span class="font-mono text-[11px] text-bone/70"
                    >{artwork.discord.date}</span
                  >
                </div>
              </div>

              <!-- Diagonal stamp overlay -->
              <div
                class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"
              >
                <div
                  class="border-2 border-spark/15 text-spark/15 font-mono text-[10px] uppercase tracking-[4px] px-4 py-1 -rotate-[15deg]"
                >
                  Archived
                </div>
              </div>
            </div>

            <!-- Reference number -->
            <p class="font-mono text-[8px] text-ash/20 mt-4">
              REF: IAG-2026-{artwork.id.split("-")[0]}
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
